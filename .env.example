# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Pre-fill the login screen automatically (both required for auto-login on startup)
SONAR_TOKEN=your_token_here
SONAR_ENTERPRISE_KEY=your-enterprise-key

# Also used by test scripts: node test-api.js / test-e2e.js / test-service.js
